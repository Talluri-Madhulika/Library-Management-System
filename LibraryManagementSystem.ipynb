      "source": [
        "books = [\"Python\", \"Java\", \"Data Science\"]\n",
        "\n",
        "print(\"Available Books:\", books)\n",
        "\n",
        "book = input(\"Enter Book Name to Borrow: \")\n",
        "\n",
        "if book in books:\n",
        "    books.remove(book)\n",
        "    print(\"Book Issued Successfully\")\n",
        "else:\n",
        "    print(\"Book Not Available\")\n",
        "\n",
        "print(\"Remaining Books:\", books)"
      ]
    }
